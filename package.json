{
  "name": "water-quality-monitor",
  "version": "1.0.2",
  "private": true,
  "description": "Real-time water quality monitoring dashboard with TTN integration",
  "author": "",
  "license": "MIT",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Junaid-Abdul-Alim/Joseph-Water-Tank.git"
  },
  "githubRelease": {
    "owner": "Junaid-Abdul-Alim",
    "repo": "Joseph-Water-Tank",
    "assetName": "WaterQualityMonitor-CollegePortable.zip"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "mqtt": "^5.15.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.18.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-reloader": "^1.2.3",
    "vite": "^8.1.3",
    "wait-on": "^7.2.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "cd bridge-server && npm install",
    "bridge": "cd bridge-server && npm start",
    "start": "concurrently -k --names \"BRIDGE,REACT\" --prefix-colors \"green,cyan\" \"npm run bridge\" \"npm run dev\"",
    "electron:dev": "concurrently -k --names \"VITE,ELECTRON\" --prefix-colors \"cyan,blue\" \"npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:start": "electron .",
    "release:github": "powershell -ExecutionPolicy Bypass -File .\\create-github-release-package.ps1",
    "package:win": "vite build && electron-builder --win --x64",
    "package:mac": "vite build && electron-builder --mac",
    "package:linux": "vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.waterqualitymonitor.app",
    "productName": "Water Quality Monitor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "bridge-server/**/*",
      "!bridge-server/.env",
      "!bridge-server/node_modules/**/*",
      "!bridge-server/*.db",
      "!bridge-server/*.db-*",
      "!bridge-server/*.sqlite",
      "!bridge-server/*.sqlite-*",
      "!bridge-server/sensor_readings.json",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "tools",
        "to": "tools",
        "filter": [
          "*.ps1"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
